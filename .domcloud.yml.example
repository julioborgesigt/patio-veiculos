source: https://github.com/julioborgesigt/patio-veiculos

features:
  - node lts

passenger:
  enabled: "on"
  app_start_command: node dist/index.js

commands:
  - git pull origin main --ff-only
  - corepack enable
  # Apenas dependências de runtime: o bundle do servidor é gerado com
  # `--packages=external`, então express/mysql2/@aws-sdk/exceljs/etc. precisam
  # existir em node_modules. (O build do FRONTEND NÃO roda aqui — veja abaixo.)
  #
  # `--ignore-scripts`: o host NÃO builda nada (baixa o dist/ pronto da branch
  # "build"), então esbuild/vite só estão presentes como devDeps e seus
  # postinstall não fazem falta em runtime. Pular esses scripts evita que o
  # postinstall do esbuild (que falha ao baixar/validar o binário no host)
  # derrube o deploy inteiro.
  - pnpm install --no-frozen-lockfile --ignore-scripts
  # Criar .env para que o app tenha as variáveis em runtime (dotenv/config)
  - |
    cat > .env << 'ENVEOF'
    DATABASE_URL=mysql://SEU_USUARIO_DB:SUA_SENHA_DB@localhost/SEU_BANCO_DB
    DB_HOST=localhost
    DB_USER=SEU_USUARIO_DB
    DB_PASSWORD=SUA_SENHA_DB
    DB_NAME=SEU_BANCO_DB
    JWT_SECRET=GERE_COM_openssl_rand_-base64_32
    API_PLACAS_TOKEN=SEU_TOKEN_API_PLACAS
    ADMIN_USER=admin
    ADMIN_PASSWORD=SUA_SENHA_ADMIN
    NODE_ENV=production
    ENVEOF
  # ───────────────────────────────────────────────────────────────────────────
  # BUILD: NÃO rodamos `pnpm build` aqui de propósito.
  # O DOM Cloud limita a memória do build (~160 MB) e o `vite build` precisa de
  # ~300-400 MB, então o deploy quebrava com "JavaScript heap out of memory".
  # O build é feito no GitHub Actions (.github/workflows/deploy.yml), que publica
  # o dist/ já compilado na branch "build". Aqui apenas baixamos esse dist/.
  # IMPORTANTE: faça o deploy só DEPOIS do workflow do GitHub Actions ficar verde.
  # ───────────────────────────────────────────────────────────────────────────
  - git fetch origin build --depth 1
  - rm -rf dist
  - git checkout FETCH_HEAD -- dist
  - |
    if [ ! -f dist/index.js ] || [ ! -f dist/public/index.html ]; then
      echo "ERRO: dist/ pré-construído não encontrado na branch 'build'."
      echo "Rode/aguarde o workflow 'Build and Deploy' no GitHub Actions e refaça o deploy."
      exit 1
    fi
  - |
    if [ -f dist/BUILD_INFO ]; then
      BUILT="$(cat dist/BUILD_INFO)"; HEAD="$(git rev-parse HEAD)"
      if [ "$BUILT" = "$HEAD" ]; then
        echo "OK: dist/ corresponde ao commit atual ($HEAD)."
      else
        echo "AVISO: dist/ foi gerado em $BUILT, mas a main está em $HEAD."
        echo "       Aguarde o GitHub Actions terminar e refaça o deploy se precisar do código mais recente."
      fi
    fi
  - export DATABASE_URL='mysql://SEU_USUARIO_DB:SUA_SENHA_DB@localhost/SEU_BANCO_DB' && node scripts/migrate-production.mjs
  - export DATABASE_URL='mysql://SEU_USUARIO_DB:SUA_SENHA_DB@localhost/SEU_BANCO_DB' && export ADMIN_USER='admin' && export ADMIN_PASSWORD='SUA_SENHA_ADMIN' && node scripts/seed-admin.mjs
  # Manutenção de disco: poda pacotes não referenciados do store do pnpm para
  # não acumular versões antigas a cada deploy. (O cache do npm não cresce mais
  # porque removemos o `npm install`.)
  - corepack pnpm store prune || true
  - mkdir -p tmp && touch tmp/restart.txt
