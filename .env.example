# =============================================================================
# AMBIENTE - Configurações obrigatórias para rodar o projeto
# =============================================================================

# Ambiente: development ou production
NODE_ENV=development

# Porta do servidor (padrão: 3000)
PORT=3000

# =============================================================================
# BANCO DE DADOS
# =============================================================================

# URL de conexão MySQL
# Formato: mysql://usuario:senha@host:porta/database
DATABASE_URL=mysql://root:senha@localhost:3306/patio_veiculos

# =============================================================================
# AUTENTICAÇÃO
# =============================================================================

# Secret para assinar JWT de sessão (gere com: openssl rand -base64 32)
# Em desenvolvimento pode usar qualquer string
JWT_SECRET=dev-secret-change-in-production

# Usuário admin (criado automaticamente na primeira execução se não existir)
# ADMIN_PASSWORD é obrigatório para que o admin seja criado
ADMIN_USER=admin
ADMIN_PASSWORD=

# =============================================================================
# API EXTERNA - CONSULTA DE PLACAS (Opcional)
# =============================================================================

# Token da API Placas (apiplacas.com.br)
# Deixe em branco para desabilitar consulta de placas
API_PLACAS_TOKEN=

# =============================================================================
# STORAGE (Opcional)
# =============================================================================

# URL da API de storage (para upload de arquivos)
BUILT_IN_FORGE_API_URL=

# Chave da API de storage
BUILT_IN_FORGE_API_KEY=

# =============================================================================
# STORAGE DE FOTOS (Opcional)
# Suporta Cloudflare R2 (gratuito) e AWS S3.
#
# ── Cloudflare R2 (recomendado — 10 GB grátis, sem cobrança de egress) ──────
#   1. dash.cloudflare.com → R2 → Create bucket
#   2. Settings do bucket → Public access → Allow access (anote a URL pública)
#   3. Manage R2 API tokens → Create API Token (Object Read & Write)
#   4. Preencha as variáveis abaixo:
#
#      AWS_REGION=auto
#      AWS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#      AWS_S3_PUBLIC_URL=https://pub-<hash>.r2.dev
#
# ── AWS S3 (alternativa paga) ────────────────────────────────────────────────
#   Deixe AWS_S3_ENDPOINT e AWS_S3_PUBLIC_URL em branco.
#   Configure bucket policy com leitura pública em vehicles/*.
#   AWS_REGION=us-east-1
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=

# =============================================================================
# CORS (Opcional - apenas produção)
# =============================================================================

# Origem permitida para CORS (ex: https://seu-dominio.com)
# Se não definido: em produção BLOQUEIA todas as origens; em dev aceita todas
CORS_ORIGIN=
