# =============================================================================
# AMBIENTE - Configurações obrigatórias para rodar o projeto
# =============================================================================

# Ambiente: development ou production
NODE_ENV=development

# Porta do servidor (padrão: 3000)
PORT=3000

# =============================================================================
# BANCO DE DADOS
# =============================================================================

# URL de conexão MySQL
# Formato: mysql://usuario:senha@host:porta/database
DATABASE_URL=mysql://root:senha@localhost:3306/patio_veiculos

# =============================================================================
# AUTENTICAÇÃO
# =============================================================================

# Secret para assinar JWT de sessão (gere com: openssl rand -base64 32)
# Em desenvolvimento pode usar qualquer string
JWT_SECRET=dev-secret-change-in-production

# Usuário admin (criado automaticamente na primeira execução se não existir)
# ADMIN_PASSWORD é obrigatório para que o admin seja criado
ADMIN_USER=admin
ADMIN_PASSWORD=

# =============================================================================
# API EXTERNA - CONSULTA DE PLACAS (Opcional)
# =============================================================================

# Token da API Placas (apiplacas.com.br)
# Deixe em branco para desabilitar consulta de placas
API_PLACAS_TOKEN=

# =============================================================================
# STORAGE (Opcional)
# =============================================================================

# URL da API de storage (para upload de arquivos)
BUILT_IN_FORGE_API_URL=

# Chave da API de storage
BUILT_IN_FORGE_API_KEY=

# =============================================================================
# AWS S3 - Fotos dos veículos (Opcional)
# Para habilitar upload de fotos, configure um bucket S3 e adicione uma
# bucket policy permitindo leitura pública em vehicles/* (s3:GetObject).
# Veja a documentação em: docs/s3-setup.md
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# =============================================================================
# CORS (Opcional - apenas produção)
# =============================================================================

# Origem permitida para CORS (ex: https://seu-dominio.com)
# Se não definido, aceita todas as origens
CORS_ORIGIN=
